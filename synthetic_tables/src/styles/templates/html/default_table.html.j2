<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{ document.title }} - synthetic document</title>
  <style>
    :root {
      --page-bg: {{ style.background_color }};
      --text-color: {{ style.text_color }};
      --accent-color: {{ style.accent_color }};
      --border-color: {{ style.border_color }};
      --header-bg: {{ style.header_background }};
      --font-family: {{ style.font_family }};
      --font-size: {{ style.font_size_pt }}pt;
      --line-height: {{ style.line_height }};
      --padding: {{ style.padding }}px;
      --sheet-width: {{ css.sheet_width }};
      --table-font-scale: {{ css.table_font_scale }};
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      padding: 24px;
      overflow-x: auto;
      background:
        radial-gradient(circle at top left, rgba(255,255,255,0.88), transparent 32%),
        linear-gradient(180deg, #eef5fb 0%, var(--page-bg) 100%);
      color: var(--text-color);
      font-family: var(--font-family), serif;
      font-size: var(--font-size);
      line-height: var(--line-height);
    }

    .table-wrap {
      width: var(--sheet-width);
      margin: 0;
      padding: 12px;
      background: #ffffff;
      border: 1px {{ css.border_style }} var(--border-color);
      box-shadow: 0 10px 28px rgba(15, 23, 42, 0.08);
      max-width: none;
      overflow: hidden;
    }

    .masthead {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 10px;
      margin-bottom: 12px;
    }

    .table-title {
      margin: 0 0 8px 0;
      color: var(--accent-color);
      font-size: calc(var(--font-size) * 1.2);
      letter-spacing: 0.03em;
    }

    .subtitle {
      margin: 0;
      max-width: 72ch;
      opacity: 0.82;
    }

    .stats {
      display: grid;
      grid-template-columns: repeat(2, minmax(90px, 1fr));
      gap: 8px;
      min-width: 240px;
    }

    .stat {
      border: 1px solid rgba(92, 107, 122, 0.26);
      background: rgba(248, 250, 252, 0.88);
      padding: 7px 9px;
    }

    .stat-label {
      display: block;
      font-size: 0.74em;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      opacity: 0.72;
    }

    .stat-value {
      display: block;
      margin-top: 3px;
      font-size: 1.1em;
      font-weight: 700;
    }

    .table-scroll {
      width: 100%;
      overflow-x: auto;
      overflow-y: hidden;
    }

    table {
      width: 100%;
      min-width: {{ css.table_min_width }};
      border-collapse: collapse;
      table-layout: {{ css.table_layout }};
      font-size: calc(var(--font-size) * var(--table-font-scale));
    }

    thead th {
      background: var(--header-bg);
      border: 1px {{ css.border_style }} var(--border-color);
      padding: calc(var(--padding) * 0.55) calc(var(--padding) * 0.65);
      text-align: left;
      vertical-align: bottom;
      overflow-wrap: break-word;
      word-break: normal;
      {{ css.header_emphasis_css }}
    }

    tbody td {
      border: 1px {{ css.border_style }} var(--border-color);
      padding: calc(var(--padding) * 0.55) calc(var(--padding) * 0.65);
      vertical-align: top;
      min-width: 0;
      overflow-wrap: break-word;
      word-break: normal;
      hyphens: auto;
    }

    .kind-long_text {
      overflow-wrap: break-word;
    }

    .kind-compact,
    .kind-numeric {
      overflow-wrap: break-word;
      word-break: normal;
      white-space: normal;
    }

    {% if style.zebra_striping %}
    tbody tr:nth-child(even) td {
      background: rgba(148, 163, 184, 0.08);
    }
    {% endif %}

    {% for column in columns %}
    .col-{{ loop.index0 }} {
      text-align: {{ column.alignment }};
      width: {{ column.width }};
    }
    {% endfor %}
  </style>
</head>
<body>
  <section class="table-wrap">
    <header class="masthead">
      <div>
        <h1 class="table-title">{{ document.title }}</h1>
        <p class="subtitle">{{ document.subtitle }}</p>
      </div>
      <div class="stats">
        {% for stat in document.stats %}
        <div class="stat">
          <span class="stat-label">{{ stat.label }}</span>
          <span class="stat-value">{{ stat.value }}</span>
        </div>
        {% endfor %}
      </div>
    </header>
    <div class="table-scroll">
      <table aria-label="{{ table.name }}">
        <thead>
          <tr>
            {% for column in columns %}
            <th class="col-{{ loop.index0 }} kind-{{ column.kind }}">{{ column.display_name }}</th>
            {% endfor %}
          </tr>
        </thead>
        <tbody>
          {% for row in rows %}
          <tr>
            {% for cell in row %}
            <td class="col-{{ loop.index0 }} kind-{{ columns[loop.index0].kind }}">{{ cell }}</td>
            {% endfor %}
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>
</body>
</html>
