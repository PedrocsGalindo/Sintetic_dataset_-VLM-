<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{ document.title }} - numeric blocks</title>
  <style>
    :root {
      --page-bg: {{ style.background_color }};
      --text-color: {{ style.text_color }};
      --accent-color: {{ style.accent_color }};
      --border-color: {{ style.border_color }};
      --header-bg: {{ style.header_background }};
      --font-family: {{ style.font_family }};
      --font-size: {{ style.font_size_pt }}pt;
      --line-height: {{ style.line_height }};
      --sheet-width: {{ css.sheet_width }};
    }

    body {
      margin: 0;
      padding: 24px;
      background:
        radial-gradient(circle at top right, rgba(255,255,255,0.86), transparent 30%),
        linear-gradient(180deg, #f7fbf8 0%, var(--page-bg) 100%);
      color: var(--text-color);
      font-family: var(--font-family), serif;
      font-size: var(--font-size);
      line-height: var(--line-height);
    }

    .numbers-sheet {
      width: var(--sheet-width);
      margin: 0 auto;
      background: rgba(255,255,255,0.96);
      border: 1px {{ css.border_style }} var(--border-color);
      padding: 20px;
      box-shadow: 0 12px 28px rgba(15, 23, 42, 0.08);
    }

    .title {
      margin: 0 0 8px 0;
      color: var(--accent-color);
      font-size: calc(var(--font-size) * 1.28);
    }

    .subtitle {
      margin: 0 0 20px 0;
      max-width: 86ch;
      opacity: 0.8;
    }

    .block-grid {
      display: grid;
      grid-template-columns: repeat({{ css.dense_grid_columns }}, minmax(0, 1fr));
      gap: 14px;
    }

    .block {
      padding: 14px;
      background: linear-gradient(180deg, rgba(216, 243, 229, 0.5), rgba(255,255,255,0.96));
      border: 1px solid rgba(74, 107, 90, 0.24);
      min-height: 170px;
    }

    .block-title {
      margin: 0 0 10px 0;
      font-size: 0.9em;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--accent-color);
    }

    .chip {
      display: grid;
      gap: 2px;
      margin-bottom: 10px;
      padding-bottom: 9px;
      border-bottom: 1px dashed rgba(74, 107, 90, 0.24);
    }

    .chip-label {
      font-size: 0.72em;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      opacity: 0.72;
    }

    .chip-value {
      font-size: 1.04em;
      font-weight: 700;
    }

    .summary {
      margin: 0;
      opacity: 0.82;
    }
  </style>
</head>
<body>
  <section class="numbers-sheet">
    <h1 class="title">{{ document.title }}</h1>
    <p class="subtitle">{{ document.subtitle }}</p>
    <section class="block-grid">
      {% for group in document.metric_groups %}
      <article class="block">
        <h2 class="block-title">{{ group.title }}</h2>
        {% for item in group.entries %}
        <div class="chip">
          <span class="chip-label">{{ item.label }}</span>
          <span class="chip-value">{{ item.value }}</span>
        </div>
        {% endfor %}
        <p class="summary">{{ group.summary }}</p>
      </article>
      {% endfor %}
    </section>
  </section>
</body>
</html>
