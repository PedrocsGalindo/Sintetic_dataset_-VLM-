<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{ document.title }} - column layout</title>
  <style>
    :root {
      --page-bg: {{ style.background_color }};
      --text-color: {{ style.text_color }};
      --accent-color: {{ style.accent_color }};
      --border-color: {{ style.border_color }};
      --header-bg: {{ style.header_background }};
      --font-family: {{ style.font_family }};
      --font-size: {{ style.font_size_pt }}pt;
      --line-height: {{ style.line_height }};
      --sheet-width: {{ css.sheet_width }};
    }

    body {
      margin: 0;
      padding: 26px;
      background:
        linear-gradient(90deg, rgba(255,255,255,0.55) 0, rgba(255,255,255,0.55) 1px, transparent 1px) 0 0 / 18px 18px,
        linear-gradient(180deg, #fbfdff 0%, var(--page-bg) 100%);
      color: var(--text-color);
      font-family: var(--font-family), serif;
      font-size: var(--font-size);
      line-height: var(--line-height);
    }

    .sheet {
      width: var(--sheet-width);
      margin: 0 auto;
      background: rgba(255,255,255,0.96);
      border: 1px {{ css.border_style }} var(--border-color);
      padding: 22px;
      box-shadow: 0 14px 32px rgba(15, 23, 42, 0.08);
    }

    .header {
      display: flex;
      justify-content: space-between;
      gap: 20px;
      margin-bottom: 20px;
    }

    .title {
      margin: 0 0 10px 0;
      color: var(--accent-color);
      font-size: calc(var(--font-size) * 1.34);
    }

    .subtitle {
      margin: 0;
      max-width: 74ch;
      opacity: 0.8;
    }

    .stats {
      display: grid;
      grid-template-columns: repeat(2, minmax(100px, 1fr));
      gap: 10px;
      min-width: 250px;
    }

    .stat {
      padding: 10px 12px;
      border: 1px solid rgba(92, 107, 122, 0.22);
      background: linear-gradient(180deg, rgba(255,255,255,1), rgba(245,248,252,0.92));
    }

    .stat-label {
      font-size: 0.72em;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      opacity: 0.7;
    }

    .stat-value {
      margin-top: 6px;
      display: block;
      font-size: 1.12em;
      font-weight: 700;
    }

    .record-list {
      display: grid;
      gap: 16px;
    }

    .record-card {
      margin: 0;
      padding: 16px 16px 14px 16px;
      background: linear-gradient(180deg, rgba(255,255,255,0.96), rgba(247,250,252,0.92));
      border-top: 4px solid var(--accent-color);
      border-left: 1px solid rgba(92, 107, 122, 0.18);
      border-right: 1px solid rgba(92, 107, 122, 0.18);
      border-bottom: 1px solid rgba(92, 107, 122, 0.18);
    }

    .record-tag {
      display: inline-block;
      margin-bottom: 8px;
      font-size: 0.72em;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--accent-color);
    }

    .inline-summary {
      margin: 0 0 14px 0;
      padding: 12px 14px;
      background: linear-gradient(90deg, rgba(220, 235, 250, 0.56), rgba(255,255,255,0.98) 24%);
      border-left: 4px solid var(--accent-color);
      line-height: 1.6;
    }

    .inline-label {
      font-weight: 700;
    }

    .inline-divider {
      opacity: 0.42;
      margin: 0 8px;
    }

    .field-columns {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px 16px;
    }

    .field-card {
      padding: 12px 13px;
      background: rgba(255,255,255,0.92);
      border: 1px dashed rgba(92, 107, 122, 0.22);
      min-height: 72px;
    }

    .field-card p {
      margin: 0;
    }

    .field-label {
      font-weight: 700;
    }
  </style>
</head>
<body>
  <section class="sheet">
    <header class="header">
      <div>
        <h1 class="title">{{ document.title }}</h1>
        <p class="subtitle">{{ document.subtitle }}</p>
      </div>
      <div class="stats">
        {% for stat in document.stats %}
        <div class="stat">
          <div class="stat-label">{{ stat.label }}</div>
          <span class="stat-value">{{ stat.value }}</span>
        </div>
        {% endfor %}
      </div>
    </header>
    <section class="record-list">
      {% for record in document.records %}
      <article class="record-card">
        <span class="record-tag">{{ record.record_label }}</span>
        <p class="inline-summary">
          {% for field in record.line_fields %}
          <span><span class="inline-label">{{ field.label }}:</span> {{ field.value }}</span>{% if not loop.last %}<span class="inline-divider">|</span>{% endif %}
          {% endfor %}
        </p>
        <div class="field-columns">
          {% for field in record.column_fields %}
          <article class="field-card">
            <p><span class="field-label">{{ field.label }}:</span> {{ field.value }}</p>
          </article>
          {% endfor %}
        </div>
      </article>
      {% endfor %}
    </section>
  </section>
</body>
</html>
