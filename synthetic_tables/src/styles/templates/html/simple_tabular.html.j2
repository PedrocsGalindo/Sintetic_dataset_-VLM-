<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{ document.title }} - simple tabular</title>
  <style>
    :root {
      --page-bg: {{ style.background_color }};
      --text-color: {{ style.text_color }};
      --accent-color: {{ style.accent_color }};
      --border-color: {{ style.border_color }};
      --header-bg: {{ style.header_background }};
      --font-family: {{ style.font_family }};
      --font-size: {{ style.font_size_pt }}pt;
      --line-height: {{ style.line_height }};
      --padding: {{ style.padding }}px;
      --sheet-width: {{ css.sheet_width }};
      --table-font-scale: {{ css.table_font_scale }};
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      padding: 24px;
      background: linear-gradient(180deg, #f5f8fb 0%, var(--page-bg) 100%);
      color: var(--text-color);
      font-family: var(--font-family), serif;
      font-size: var(--font-size);
      line-height: var(--line-height);
    }

    .sheet {
      width: var(--sheet-width);
      margin: 0 auto;
      padding: 20px;
      background: #ffffff;
      border: 1px {{ css.border_style }} var(--border-color);
      box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
      max-width: 100%;
      overflow: hidden;
    }

    .masthead {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 18px;
      margin-bottom: 16px;
    }

    .title {
      margin: 0 0 8px 0;
      color: var(--accent-color);
      font-size: calc(var(--font-size) * 1.2);
    }

    .subtitle {
      margin: 0;
      opacity: 0.8;
    }

    .stats {
      display: grid;
      grid-template-columns: repeat(2, minmax(96px, 1fr));
      gap: 10px;
      min-width: 220px;
    }

    .stat {
      padding: 10px 12px;
      border: 1px solid rgba(92, 107, 122, 0.22);
      background: rgba(248, 250, 252, 0.92);
    }

    .stat-label {
      display: block;
      font-size: 0.72em;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      opacity: 0.72;
    }

    .stat-value {
      display: block;
      margin-top: 5px;
      font-weight: 700;
    }

    .table-scroll {
      width: 100%;
      overflow-x: auto;
    }

    .table-block + .table-block {
      margin-top: 18px;
    }

    .block-title {
      margin: 0 0 8px 0;
      font-size: calc(var(--font-size) * 0.95);
      color: var(--accent-color);
    }

    table {
      width: 100%;
      border-collapse: collapse;
      table-layout: {{ css.table_layout }};
      font-size: calc(var(--font-size) * var(--table-font-scale));
    }

    thead th {
      background: var(--header-bg);
      border: 1px {{ css.border_style }} var(--border-color);
      padding: var(--padding);
      text-align: left;
      vertical-align: bottom;
      overflow-wrap: break-word;
      word-break: normal;
      {{ css.header_emphasis_css }}
    }

    tbody td {
      border: 1px {{ css.border_style }} var(--border-color);
      padding: var(--padding);
      vertical-align: top;
      min-width: 0;
      overflow-wrap: break-word;
      word-break: normal;
      hyphens: auto;
    }

    .kind-long_text {
      overflow-wrap: break-word;
    }

    .kind-compact,
    .kind-numeric {
      overflow-wrap: anywhere;
    }

    {% if style.zebra_striping %}
    tbody tr:nth-child(even) td {
      background: rgba(148, 163, 184, 0.08);
    }
    {% endif %}

    {% for column in columns %}
    .col-{{ loop.index0 }} {
      text-align: {{ column.alignment }};
      width: {{ column.width }};
    }
    {% endfor %}
  </style>
</head>
<body>
  <section class="sheet">
    <header class="masthead">
      <div>
        <h1 class="title">{{ document.title }}</h1>
        <p class="subtitle">{{ document.subtitle }}</p>
      </div>
      <div class="stats">
        {% for stat in document.stats %}
        <div class="stat">
          <span class="stat-label">{{ stat.label }}</span>
          <span class="stat-value">{{ stat.value }}</span>
        </div>
        {% endfor %}
      </div>
    </header>
    {% for section in table_sections %}
    <section class="table-block">
      {% if table_sections|length > 1 %}
      <h2 class="block-title">{{ section.title }}</h2>
      {% endif %}
    <div class="table-scroll">
      <table aria-label="{{ table.name }}">
        <thead>
          <tr>
            {% for column in section.columns %}
            <th class="col-{{ loop.index0 }} kind-{{ column.kind }}" style="text-align: {{ column.alignment }}; width: {{ column.width }};">{{ column.display_name }}</th>
            {% endfor %}
          </tr>
        </thead>
        <tbody>
          {% for row in section.rows %}
          <tr>
            {% for cell in row %}
            {% set column = section.columns[loop.index0] %}
            <td class="col-{{ loop.index0 }} kind-{{ column.kind }}" style="text-align: {{ column.alignment }}; width: {{ column.width }};">{{ cell }}</td>
            {% endfor %}
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    </section>
    {% endfor %}
  </section>
</body>
</html>
