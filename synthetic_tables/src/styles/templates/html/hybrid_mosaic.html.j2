<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{ document.title }} - hybrid mosaic</title>
  <style>
    :root {
      --page-bg: {{ style.background_color }};
      --text-color: {{ style.text_color }};
      --accent-color: {{ style.accent_color }};
      --border-color: {{ style.border_color }};
      --header-bg: {{ style.header_background }};
      --font-family: {{ style.font_family }};
      --font-size: {{ style.font_size_pt }}pt;
      --line-height: {{ style.line_height }};
      --sheet-width: {{ css.sheet_width }};
    }

    body {
      margin: 0;
      padding: 26px;
      background:
        radial-gradient(circle at top left, rgba(255,255,255,0.88), transparent 30%),
        linear-gradient(180deg, #eef4fa 0%, var(--page-bg) 100%);
      color: var(--text-color);
      font-family: var(--font-family), serif;
      font-size: var(--font-size);
      line-height: var(--line-height);
    }

    .sheet {
      width: var(--sheet-width);
      margin: 0 auto;
      background: rgba(255,255,255,0.97);
      border: 1px {{ css.border_style }} var(--border-color);
      padding: 22px;
      box-shadow: 0 14px 34px rgba(15, 23, 42, 0.08);
    }

    .masthead {
      display: flex;
      justify-content: space-between;
      gap: 22px;
      margin-bottom: 18px;
    }

    .title {
      margin: 0 0 10px 0;
      color: var(--accent-color);
      font-size: calc(var(--font-size) * 1.34);
    }

    .subtitle {
      margin: 0;
      max-width: 82ch;
      opacity: 0.8;
    }

    .stats {
      display: grid;
      grid-template-columns: repeat(2, minmax(96px, 1fr));
      gap: 10px;
      min-width: 250px;
    }

    .stat {
      padding: 10px 12px;
      border: 1px solid rgba(92, 107, 122, 0.22);
      background: rgba(248, 250, 252, 0.9);
    }

    .stat-label {
      font-size: 0.72em;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      opacity: 0.72;
    }

    .stat-value {
      display: block;
      margin-top: 5px;
      font-weight: 700;
      font-size: 1.12em;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.65fr) minmax(280px, 0.95fr);
      gap: 20px;
      margin-bottom: 20px;
    }

    .lead-panel {
      padding: 18px;
      background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(243,247,252,0.94));
      border-top: 4px solid var(--accent-color);
      border-left: 1px solid rgba(92, 107, 122, 0.18);
      border-right: 1px solid rgba(92, 107, 122, 0.18);
      border-bottom: 1px solid rgba(92, 107, 122, 0.18);
    }

    .lead-kicker {
      display: inline-block;
      margin-bottom: 10px;
      font-size: 0.74em;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--accent-color);
    }

    .lead-headline {
      margin: 0 0 10px 0;
      font-size: 1.18em;
    }

    .lead-body {
      margin: 0;
    }

    .sidebar {
      display: grid;
      gap: 12px;
    }

    .mini-card {
      padding: 14px;
      background: linear-gradient(180deg, rgba(220, 235, 250, 0.5), rgba(255,255,255,0.95));
      border: 1px solid rgba(92, 107, 122, 0.22);
    }

    .mini-card h3 {
      margin: 0 0 8px 0;
      font-size: 0.9em;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--accent-color);
    }

    .mini-item {
      margin: 0 0 6px 0;
    }

    .stream-band {
      margin-bottom: 20px;
      display: grid;
      gap: 10px;
    }

    .stream-line {
      padding: 12px 14px;
      border-left: 4px solid var(--accent-color);
      background: linear-gradient(90deg, rgba(220, 235, 250, 0.58), rgba(255,255,255,0.96) 24%);
      box-shadow: inset 0 -1px 0 rgba(92, 107, 122, 0.14);
    }

    .line-label {
      display: inline-block;
      min-width: 110px;
      margin-right: 10px;
      font-weight: 700;
      color: var(--accent-color);
    }

    .segment-label {
      font-weight: 700;
    }

    .divider {
      opacity: 0.42;
      margin: 0 8px;
    }

    .column-notes {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
    }

    .note-stack {
      display: grid;
      gap: 14px;
    }

    .note-card {
      padding: 14px;
      background: rgba(255,255,255,0.94);
      border: 1px dashed rgba(92, 107, 122, 0.24);
    }

    .note-card h4 {
      margin: 0 0 8px 0;
      color: var(--accent-color);
      font-size: 0.82em;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .note-card p {
      margin: 0 0 8px 0;
    }

    .meta-line {
      font-size: 0.86em;
      opacity: 0.74;
    }
  </style>
</head>
<body>
  <section class="sheet">
    <header class="masthead">
      <div>
        <h1 class="title">{{ document.title }}</h1>
        <p class="subtitle">{{ document.subtitle }}</p>
      </div>
      <div class="stats">
        {% for stat in document.stats %}
        <div class="stat">
          <span class="stat-label">{{ stat.label }}</span>
          <span class="stat-value">{{ stat.value }}</span>
        </div>
        {% endfor %}
      </div>
    </header>

    <section class="hero-grid">
      <article class="lead-panel">
        <span class="lead-kicker">{{ document.article_sections[0].label if document.article_sections else 'Overview' }}</span>
        <h2 class="lead-headline">{{ document.article_sections[0].title if document.article_sections else document.title }}</h2>
        <p class="lead-body">{{ document.article_sections[0].paragraph if document.article_sections else document.subtitle }}</p>
      </article>
      <aside class="sidebar">
        {% for group in document.metric_groups[:3] %}
        <section class="mini-card">
          <h3>{{ group.title }}</h3>
          {% for entry in group.entries[:3] %}
          <p class="mini-item"><strong>{{ entry.label }}:</strong> {{ entry.value }}</p>
          {% endfor %}
        </section>
        {% endfor %}
      </aside>
    </section>

    <section class="stream-band">
      {% for row in document.stream_rows[:12] %}
      <p class="stream-line">
        <span class="line-label">{{ row.label }}</span>
        {% for segment in row.segments[:5] %}
        <span><span class="segment-label">{{ segment.label }}:</span> {{ segment.value }}</span>{% if not loop.last %}<span class="divider">|</span>{% endif %}
        {% endfor %}
      </p>
      {% endfor %}
    </section>

    <section class="column-notes">
      {% for column in document.article_columns %}
      <div class="note-stack">
        {% for article in column %}
        <article class="note-card">
          <h4>{{ article.label }}</h4>
          <p>{{ article.paragraph }}</p>
          <p class="meta-line">{{ article.meta_line }}</p>
        </article>
        {% endfor %}
      </div>
      {% endfor %}
    </section>
  </section>
</body>
</html>
