<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{ document.title }} - editorial blocks</title>
  <style>
    :root {
      --page-bg: {{ style.background_color }};
      --text-color: {{ style.text_color }};
      --accent-color: {{ style.accent_color }};
      --border-color: {{ style.border_color }};
      --header-bg: {{ style.header_background }};
      --font-family: {{ style.font_family }};
      --font-size: {{ style.font_size_pt }}pt;
      --line-height: {{ style.line_height }};
      --sheet-width: {{ css.sheet_width }};
    }

    body {
      margin: 0;
      padding: 10px 12px;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.52), transparent 18%),
        linear-gradient(180deg, #f6f8fb 0%, var(--page-bg) 100%);
      color: var(--text-color);
      font-family: var(--font-family), serif;
      font-size: var(--font-size);
      line-height: var(--line-height);
    }

    .sheet {
      width: var(--sheet-width);
      margin: 0;
      background: rgba(255,255,255,0.97);
      border: 1px {{ css.border_style }} var(--border-color);
      padding: 12px;
      box-shadow: 0 12px 30px rgba(15, 23, 42, 0.08);
      max-width: 100%;
      box-sizing: border-box;
    }

    .title {
      margin: 0 0 10px 0;
      color: var(--accent-color);
      font-size: calc(var(--font-size) * 1.34);
    }

    .subtitle {
      margin: 0 0 12px 0;
      max-width: 88ch;
      opacity: 0.8;
    }

    .editorial-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.35fr) minmax(280px, 0.85fr);
      gap: 12px;
      margin-bottom: 12px;
    }

    .article-stack {
      display: grid;
      gap: 10px;
    }

    .article-block {
      padding: 10px;
      background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(247,250,252,0.92));
      border-top: 3px solid var(--accent-color);
      border-left: 1px solid rgba(92, 107, 122, 0.18);
      border-right: 1px solid rgba(92, 107, 122, 0.18);
      border-bottom: 1px solid rgba(92, 107, 122, 0.18);
    }

    .article-block h2 {
      margin: 0 0 8px 0;
      font-size: 1.02em;
    }

    .article-block p {
      margin: 0 0 9px 0;
    }

    .meta-line {
      font-size: 0.86em;
      opacity: 0.74;
    }

    .sidebar {
      display: grid;
      gap: 9px;
    }

    .sidebar-card {
      padding: 9px;
      background: linear-gradient(180deg, rgba(220, 235, 250, 0.48), rgba(255,255,255,0.96));
      border: 1px solid rgba(92, 107, 122, 0.2);
    }

    .sidebar-card h3 {
      margin: 0 0 8px 0;
      font-size: 0.84em;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--accent-color);
    }

    .stats {
      display: grid;
      grid-template-columns: repeat(2, minmax(90px, 1fr));
      gap: 8px;
    }

    .stat {
      padding: 7px 9px;
      border: 1px solid rgba(92, 107, 122, 0.18);
      background: rgba(248, 250, 252, 0.92);
    }

    .stat-label {
      display: block;
      font-size: 0.72em;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      opacity: 0.72;
    }

    .stat-value {
      display: block;
      margin-top: 3px;
      font-weight: 700;
      font-size: 1.08em;
    }

    .ribbon {
      display: grid;
      gap: 7px;
    }

    .ribbon-row {
      padding: 8px 10px;
      background: rgba(255,255,255,0.92);
      border-bottom: 1px dashed rgba(92, 107, 122, 0.24);
    }

    .ribbon-label {
      display: inline-block;
      min-width: 110px;
      font-weight: 700;
      color: var(--accent-color);
    }
  </style>
</head>
<body>
  <section class="sheet">
    <h1 class="title">{{ document.title }}</h1>
    <p class="subtitle">{{ document.subtitle }}</p>

    <section class="editorial-grid">
      <div class="article-stack">
        {% for article in document.article_sections[:5] %}
        <article class="article-block">
          <h2>{{ article.title }}</h2>
          <p>{{ article.paragraph }}</p>
          <p class="meta-line">{{ article.meta_line }}</p>
        </article>
        {% endfor %}
      </div>

      <aside class="sidebar">
        <section class="sidebar-card">
          <h3>Page Stats</h3>
          <div class="stats">
            {% for stat in document.stats %}
            <div class="stat">
              <span class="stat-label">{{ stat.label }}</span>
              <span class="stat-value">{{ stat.value }}</span>
            </div>
            {% endfor %}
          </div>
        </section>

        {% for group in document.metric_groups[:3] %}
        <section class="sidebar-card">
          <h3>{{ group.title }}</h3>
          {% for entry in group.entries[:4] %}
          <p><strong>{{ entry.label }}:</strong> {{ entry.value }}</p>
          {% endfor %}
        </section>
        {% endfor %}
      </aside>
    </section>

    <section class="ribbon">
      {% for row in document.stream_rows[:10] %}
      <p class="ribbon-row">
        <span class="ribbon-label">{{ row.label }}</span>
        {% for segment in row.segments[:4] %}
        <span><strong>{{ segment.label }}:</strong> {{ segment.value }}</span>{% if not loop.last %} <span style="opacity:0.42;">|</span> {% endif %}
        {% endfor %}
      </p>
      {% endfor %}
    </section>
  </section>
</body>
</html>
